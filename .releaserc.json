{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/update-manifest.js ${nextRelease.version} && mkdir -p dist && zip -r dist/akamai-debug-helper-${nextRelease.version}.zip background.js manifest.json popup icons"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/akamai-debug-helper-${nextRelease.version}.zip",
            "label": "Extension ZIP"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["manifest.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
