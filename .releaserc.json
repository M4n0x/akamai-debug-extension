{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/build-release.js ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/akamai-debug-helper-*-firefox.zip",
            "label": "Firefox Extension ZIP"
          },
          {
            "path": "dist/akamai-debug-helper-*-chromium.zip",
            "label": "Chromium Extension ZIP"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["manifest.json", "manifest.chrome.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
